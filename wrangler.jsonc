{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "skystone-co",
  "compatibility_date": "2025-10-01",
  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "skystone.co", "custom_domain": true },
    { "pattern": "www.skystone.co", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
