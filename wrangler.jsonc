{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "skystone-co",
  "compatibility_date": "2025-10-01",
  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
  // Custom domains skystone.co + www.skystone.co are attached via the
  // Workers Domains API (account-scoped) rather than `routes` here, since
  // the CI API token lacks Zone → Workers Routes edit permission.
}
